# ══════════════════════════════════════════════════════════
# UNIFIX – Environment Variables (MongoDB version)
# Copy this to .env and fill in your values
# ══════════════════════════════════════════════════════════

# ── Flask ──────────────────────────────────────────────────
FLASK_ENV=development
SECRET_KEY=change-this-to-a-long-random-string
JWT_SECRET_KEY=change-this-jwt-secret-too

# ── MongoDB ────────────────────────────────────────────────
# Local MongoDB (default, no auth needed for dev)
MONGO_URI=mongodb://localhost:27017
MONGO_DB=unifix_db

# MongoDB Atlas (cloud) — use this for production:
# MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority
# MONGO_DB=unifix_db

# ── Email (leave blank to use console logging in dev) ──────
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=UNIFIX System <noreply@unifix.edu>

# ── File Uploads ───────────────────────────────────────────
UPLOAD_FOLDER=uploads
MAX_CONTENT_LENGTH=16777216

# ── Frontend URL (used in email links) ────────────────────
FRONTEND_URL=http://localhost:3000
