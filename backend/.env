# ═══════════════════════════════════════════════════════════════════
# UNIFIX – Environment Configuration
# ═══════════════════════════════════════════════════════════════════

# ── SECURITY ────────────────────────────────────────────────────────
# Generate random keys at: https://randomkeygen.com/
SECRET_KEY=UNIFIX-SECRET-KEY-2024-CHANGE-THIS-IN-PRODUCTION-ABC123DEF456
JWT_SECRET_KEY=UNIFIX-JWT-SECRET-2024-CHANGE-THIS-IN-PRODUCTION-XYZ789UVW012

# ── DATABASE ────────────────────────────────────────────────────────
# For local MongoDB (keep these defaults)
MONGO_URI=mongodb://localhost:27017
MONGO_DB=unifix_db

# For MongoDB Atlas (cloud) - uncomment and use this instead:
# MONGO_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
# MONGO_DB=unifix_db

# ── EMAIL CONFIGURATION ──────────────────────────────────────────────
# Leave empty to print emails to console (good for development)
# For production, configure with real SMTP settings

MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=UNIFIX <noreply@university.edu>

# Gmail setup instructions:
# 1. Enable 2-Step Verification on your Google Account
# 2. Go to Security → App Passwords → Create new app password
# 3. Use the app password (not your regular password) above

# ── FILE UPLOADS ────────────────────────────────────────────────────
UPLOAD_FOLDER=./uploads
MAX_CONTENT_LENGTH=16777216

# ── FRONTEND URL ────────────────────────────────────────────────────
# Development: http://localhost:3000
# Production: https://your-domain.com
FRONTEND_URL=http://localhost:3000

# ── JWT SETTINGS ────────────────────────────────────────────────────
JWT_ACCESS_TOKEN_EXPIRES=86400

# ═══════════════════════════════════════════════════════════════════
# PRODUCTION CHECKLIST:
# ═══════════════════════════════════════════════════════════════════
# ✅ Change SECRET_KEY to a random string
# ✅ Change JWT_SECRET_KEY to a different random string  
# ✅ Configure MAIL_USERNAME and MAIL_PASSWORD
# ✅ Update FRONTEND_URL to your production domain
# ✅ Use MongoDB Atlas or secure MongoDB instance
# ═══════════════════════════════════════════════════════════════════
